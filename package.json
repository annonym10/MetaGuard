{
  "name": "metaguard",
  "version": "1.0.0",
  "description": "Приложение для удаления метаданных из файлов",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "security",
    "metadata",
    "privacy",
    "electron"
  ],
  "author": "annonym10",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "mammoth": "^1.7.0",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "electron": "^25.5.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.metaguard.app",
    "productName": "MetaGuard",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
